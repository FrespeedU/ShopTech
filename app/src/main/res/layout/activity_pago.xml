<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:padding="@dimen/padding_estandar"
    tools:context=".PagoActivity">

    <TextView
        android:id="@+id/tvTituloPago"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Pasarela de Pagos"
        android:textColor="@color/neon_azul"
        android:textSize="@dimen/text_size_titulo"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvMontoPagar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="@color/neon_verde"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloPago"
        tools:text="Total a pagar: $0" />

    <EditText
        android:id="@+id/etNumeroTarjeta"
        android:layout_width="0dp"
        android:layout_height="@dimen/alto_input"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Número de Tarjeta (16 dígitos)"
        android:inputType="number"
        android:maxLength="16"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvMontoPagar" />

    <LinearLayout
        android:id="@+id/llFechas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/etNumeroTarjeta">

        <EditText
            android:id="@+id/etVencimiento"
            android:layout_width="0dp"
            android:layout_height="@dimen/alto_input"
            android:layout_weight="1"
            android:backgroundTint="@color/neon_azul"
            android:hint="MM/AA"
            android:inputType="text"
            android:maxLength="5"
            android:textColor="@color/white"
            android:textColorHint="@color/texto_secundario" />

        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/etCVV"
            android:layout_width="0dp"
            android:layout_height="@dimen/alto_input"
            android:layout_weight="1"
            android:backgroundTint="@color/neon_azul"
            android:hint="CVV (3 dígitos)"
            android:inputType="numberPassword"
            android:maxLength="3"
            android:textColor="@color/white"
            android:textColorHint="@color/texto_secundario" />
    </LinearLayout>

    <EditText
        android:id="@+id/etTitular"
        android:layout_width="0dp"
        android:layout_height="@dimen/alto_input"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Nombre del Titular"
        android:inputType="textPersonName"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llFechas" />

    <Button
        android:id="@+id/btnProcesarPago"
        android:layout_width="0dp"
        android:layout_height="@dimen/alto_boton"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/neon_fucsia"
        android:text="Pagar Ahora"
        android:textColor="@color/white"
        android:textSize="@dimen/text_size_boton"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>