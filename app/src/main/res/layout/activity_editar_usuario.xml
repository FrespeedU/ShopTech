<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloEditarUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; Editar Usuario"
        android:textColor="@color/neon_azul"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivIconoUsuario"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="32dp"
        android:src="@android:drawable/ic_delete"
        app:tint="@color/neon_azul"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloEditarUsuario" />

    <EditText
        android:id="@+id/etNombreCompleto"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Nombre completo"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/ivIconoUsuario" />

    <EditText
        android:id="@+id/etCorreoEdit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Correo electrónico"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/etNombreCompleto" />

    <EditText
        android:id="@+id/etRolUsuario"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Rol de usuario"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/etCorreoEdit" />

    <EditText
        android:id="@+id/etEstadoCuenta"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Estado de cuenta"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/etRolUsuario" />

    <Button
        android:id="@+id/btnGuardarUsuario"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/neon_verde"
        android:text="Guardar Cambios"
        android:textColor="@color/fondo_oscuro"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>