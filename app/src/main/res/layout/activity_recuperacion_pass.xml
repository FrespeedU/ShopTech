<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloRecuperar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; Recuperar Contraseña"
        android:textColor="@color/neon_azul"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvInstrucciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Ingresa el correo electrónico asociado a tu cuenta. Te enviaremos un enlace para restablecer tu acceso."
        android:textColor="@color/texto_secundario"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloRecuperar" />

    <EditText
        android:id="@+id/etCorreoRecuperar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/neon_azul"
        android:hint="Correo electrónico"
        android:inputType="textEmailAddress"
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/tvInstrucciones" />

    <Button
        android:id="@+id/btnEnviarEnlace"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="@color/neon_fucsia"
        android:text="Enviar Enlace"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/etCorreoRecuperar" />

</androidx.constraintlayout.widget.ConstraintLayout>