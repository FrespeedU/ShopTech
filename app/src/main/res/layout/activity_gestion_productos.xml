<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_oscuro"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTituloProdAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt; Inventario Global"
        android:textColor="@color/neon_azul"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etBuscarProdGlobal"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/neon_verde"
        android:hint="Buscar por SKU o nombre..."
        android:textColor="@color/white"
        android:textColorHint="@color/texto_secundario"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloProdAdmin" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/etBuscarProdGlobal">

        <Button
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="8dp"
            android:text="SKU: 001 - Smartphone A55\nVendedor: John Tech"
            android:textColor="@color/white"
            app:strokeColor="@color/neon_azul" />

        <Button
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SKU: 002 - Mouse Gamer\nVendedor: PC Store"
            android:textColor="@color/white"
            app:strokeColor="@color/neon_fucsia" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>